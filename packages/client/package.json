{
  "name": "@realmfall/client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config ./vite.config.ts",
    "dev:random": "node ./scripts/run-dev-random-port.mjs",
    "dev:storybook": "storybook dev -p 6006 --config-dir ./.storybook",
    "build": "node ./scripts/run-vite-build.mjs",
    "build:budget": "pnpm build && node ./scripts/check-bundle-budget.mjs",
    "build:budget:strict":
      "pnpm build && node ./scripts/check-bundle-budget.mjs --strict",
    "build:duplicate-deps": "node ./scripts/run-duplicate-deps-audit.mjs",
    "build:visualize": "node ./scripts/run-bundle-visualizer.mjs",
    "build:storybook": "storybook build --config-dir ./.storybook",
    "assets:world-atlas": "node ./scripts/build-world-terrain-atlas.mjs",
    "serve": "node ./scripts/serve-https.mjs",
    "preview": "vite preview --config ./vite.config.ts",
    "typecheck":
      "tsc -p ./tsconfig.json --noEmit && tsc -p ./tsconfig.node.json --noEmit",
    "lint": "pnpm lint:oxlint && pnpm lint:css",
    "lint:fix":
      "oxlint -c ../../.oxlintrc.json --fix src ./.storybook ./scripts ./vite.config.ts",
    "lint:oxlint":
      "oxlint -c ../../.oxlintrc.json src ./.storybook ./scripts ./vite.config.ts",
    "lint:css": "stylelint \"src/**/*.{css,scss}\"",
    "format": "prettier --check ..",
    "test:jsdom": "node -e \"console.log('Tests are intentionally disabled')\"",
    "test:node": "node -e \"console.log('Tests are intentionally disabled')\"",
    "test": "node -e \"console.log('Tests are intentionally disabled')\"",
    "test:memory:leaks": "node -e \"console.log('Tests are intentionally disabled')\"",
    "test:memory:leaks:prod": "node -e \"console.log('Tests are intentionally disabled')\"",
    "test:watch": "node -e \"console.log('Tests are intentionally disabled')\"",
    "test:coverage": "node -e \"console.log('Tests are intentionally disabled')\"",
    "sync:ai-entrypoints": "node ./scripts/sync-ai-entrypoints.mjs",
    "update:check": "node ./scripts/dependency-updates.mjs check",
    "update:major": "node ./scripts/dependency-updates.mjs update --target major",
    "update:minor": "node ./scripts/dependency-updates.mjs update --target minor"
  },
  "dependencies": {
    "@rexa-developer/tiks": "^0.1.8",
    "pixi.js": "^8.18.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-use-audio-player": "^4.0.2"
  },
  "devDependencies": {
    "@raegen/vite-plugin-vitest-cache": "^0.3.7",
    "@rolldown/plugin-babel": "0.2.3",
    "@storybook/react-vite": "^10.3.5",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.2.1",
    "fuite": "^5.0.9",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "npm-check-updates": "^21.0.3",
    "oxlint": "^1.61.0",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.99.0",
    "selfsigned": "^5.5.0",
    "serve": "^14.2.6",
    "sharp": "^0.34.5",
    "storybook": "^10.3.5",
    "stylelint": "^17.9.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "svgo": "^4.0.1",
    "typescript": "^6.0.3",
    "unplugin-detect-duplicated-deps": "^2.0.0",
    "vite": "^8.0.10",
    "vite-plugin-minipic": "^1.3.2",
    "vitest": "^4.1.5"
  }
}
