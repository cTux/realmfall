{
  "name": "@realmfall/ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./loading-spinner": "./src/components/LoadingSpinner/LoadingSpinner.tsx"
  },
  "scripts": {
    "dev": "vite --config ./vite.config.ts",
    "build": "tsc -p ./tsconfig.build.json && vite build --config ./vite.config.ts",
    "typecheck": "tsc -p ./tsconfig.json --noEmit",
    "lint": "pnpm lint:oxlint && pnpm lint:css",
    "lint:oxlint": "oxlint -c ../../.oxlintrc.json src ./.storybook ./vite.config.ts",
    "lint:css": "stylelint \"src/**/*.{css,scss}\"",
    "dev:storybook": "storybook dev -p 6008 --config-dir ./.storybook",
    "build:storybook": "storybook build --config-dir ./.storybook"
  },
  "peerDependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@storybook/react-vite": "^10.3.5",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.0",
    "oxlint": "^1.62.0",
    "sass": "^1.99.0",
    "storybook": "^10.3.5",
    "stylelint": "^17.9.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
