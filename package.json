{
  "name": "realmfall",
  "private": true,
  "version": "0.2.470",
  "description": "Single-player browser survival RPG with hex exploration, turn-based systems, React UI, and Pixi.js world rendering.",
  "keywords": [
    "browser-game",
    "survival-rpg",
    "hex-crawl",
    "turn-based",
    "roguelite",
    "pixi.js",
    "react",
    "vite"
  ],
  "license": "UNLICENSED",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "repository": {
    "type": "git",
    "url": "git@github.com:cTux/realmfall.git"
  },
  "homepage": "https://github.com/cTux/realmfall",
  "bugs": {
    "url": "https://github.com/cTux/realmfall/issues"
  },
  "engines": {
    "node": "25.x",
    "pnpm": "10.x"
  },
  "scripts": {
    "dev": "pnpm --filter @realmfall/client dev",
    "dev:ui": "pnpm --filter @realmfall/ui dev",
    "dev:ui-storybook": "pnpm --filter @realmfall/ui dev:storybook",
    "dev:random": "pnpm --filter @realmfall/client dev:random",
    "dev:storybook": "pnpm --filter @realmfall/client dev:storybook",
    "build": "pnpm --filter @realmfall/client build",
    "build:ui": "pnpm --filter @realmfall/ui build",
    "build:budget": "pnpm --filter @realmfall/client build:budget",
    "build:budget:strict": "pnpm --filter @realmfall/client build:budget:strict",
    "build:duplicate-deps": "pnpm --filter @realmfall/client build:duplicate-deps",
    "build:visualize": "pnpm --filter @realmfall/client build:visualize",
    "build:storybook": "pnpm --filter @realmfall/client build:storybook",
    "build:ui:storybook": "pnpm --filter @realmfall/ui build:storybook",
    "assets:world-atlas": "pnpm --filter @realmfall/client assets:world-atlas",
    "git:commit": "node scripts/git-commit.mjs",
    "git:deploy": "node scripts/git-deploy.mjs",
    "git:prune-gone-branches": "node scripts/prune-gone-branches.mjs",
    "git:rebase-master-and-push": "node scripts/rebase-master-and-push.mjs",
    "serve": "pnpm --filter @realmfall/client serve",
    "preview": "pnpm --filter @realmfall/client preview",
    "quality:staged": "node scripts/run-staged-quality.mjs",
    "sync:ai-entrypoints": "pnpm --filter @realmfall/client sync:ai-entrypoints",
    "typecheck": "pnpm --filter @realmfall/client typecheck",
    "lint": "pnpm --filter @realmfall/client lint",
    "lint:fix": "pnpm --filter @realmfall/client lint:fix",
    "lint:oxlint": "pnpm --filter @realmfall/client lint:oxlint",
    "lint:css": "pnpm --filter @realmfall/client lint:css",
    "format": "pnpm --filter @realmfall/client format",
    "test:jsdom": "pnpm --filter @realmfall/client test:jsdom",
    "test:node": "pnpm --filter @realmfall/client test:node",
    "test": "pnpm --filter @realmfall/client test",
    "test:memory:leaks": "pnpm --filter @realmfall/client test:memory:leaks",
    "test:memory:leaks:prod": "pnpm --filter @realmfall/client test:memory:leaks:prod",
    "test:watch": "pnpm --filter @realmfall/client test:watch",
    "test:coverage": "pnpm --filter @realmfall/client test:coverage",
    "prepare": "husky",
    "update:check": "pnpm --filter @realmfall/client update:check",
    "update:major": "pnpm --filter @realmfall/client update:major",
    "update:minor": "pnpm --filter @realmfall/client update:minor"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "puppeteer",
      "sharp"
    ],
    "overrides": {
      "@xmldom/xmldom": "0.8.13",
      "serialize-javascript@<=7.0.2": ">=7.0.3",
      "serialize-javascript@<7.0.5": ">=7.0.5"
    }
  }
}
