{
  "name": "realmfall",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "changelog:build": "node ./scripts/changelog.mjs build",
    "changelog:release": "node ./scripts/changelog.mjs release",
    "dev": "vite",
    "dev:storybook": "storybook dev -p 6006",
    "build": "vite build",
    "build:storybook": "storybook build",
    "serve": "serve dist",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "lint": "eslint .",
    "lint:css": "stylelint \"src/**/*.{css,scss}\"",
    "format": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "update:major": "pnpm exec npm-check-updates -u --packageManager pnpm",
    "update:minor": "pnpm exec npm-check-updates -u --target minor --packageManager pnpm"
  },
  "dependencies": {
    "pixi.js": "^7.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-fps-stats": "^0.3.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@storybook/react-vite": "^10.3.5",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "npm-check-updates": "^20.0.2",
    "prettier": "^3.8.2",
    "sass": "^1.99.0",
    "serve": "^14.2.6",
    "sharp": "^0.34.5",
    "storybook": "^10.3.5",
    "stylelint": "^17.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^15.0.1",
    "svgo": "^4.0.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "unplugin-detect-duplicated-deps": "^2.0.0",
    "vite": "^6.4.2",
    "vite-plugin-minipic": "^1.3.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "serialize-javascript@<=7.0.2": ">=7.0.3",
      "serialize-javascript@<7.0.5": ">=7.0.5"
    }
  }
}
