{
  "name": "realmfall",
  "private": true,
  "version": "0.2.98",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite",
    "dev:storybook": "storybook dev -p 6006",
    "build": "vite build",
    "build:budget": "pnpm build && node scripts/check-bundle-budget.mjs",
    "check:version": "node scripts/check-package-version.mjs",
    "build:storybook": "storybook build",
    "serve": "node scripts/serve-https.mjs",
    "preview": "vite preview",
    "quality:staged": "node scripts/run-staged-quality.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "lint": "pnpm lint:oxlint",
    "lint:fix": "oxlint -c .oxlintrc.json --fix src .storybook scripts vite.config.ts commitlint.config.js",
    "lint:oxlint": "oxlint -c .oxlintrc.json src .storybook scripts vite.config.ts commitlint.config.js",
    "lint:css": "stylelint \"src/**/*.{css,scss}\"",
    "format": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "update:major": "pnpm exec npm-check-updates -u --packageManager pnpm",
    "update:minor": "pnpm exec npm-check-updates -u --target minor --packageManager pnpm"
  },
  "dependencies": {
    "pixi.js": "^8.18.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-fps-stats": "^0.3.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@storybook/react-vite": "^10.3.5",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "npm-check-updates": "^21.0.0",
    "oxlint": "^1.60.0",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "selfsigned": "^5.5.0",
    "serve": "^14.2.6",
    "sharp": "^0.34.5",
    "storybook": "^10.3.5",
    "stylelint": "^17.8.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "svgo": "^4.0.1",
    "typescript": "^6.0.2",
    "unplugin-detect-duplicated-deps": "^2.0.0",
    "vite": "^8.0.8",
    "vite-plugin-minipic": "^1.3.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "serialize-javascript@<=7.0.2": ">=7.0.3",
      "serialize-javascript@<7.0.5": ">=7.0.5"
    }
  }
}
