{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "files": {
    "includes": [
      "src/**",
      ".storybook/**",
      "scripts/**",
      "eslint.config.js",
      "vite.config.ts",
      "commitlint.config.js"
    ]
  },
  "formatter": {
    "enabled": false
  },
  "linter": {
    "rules": {
      "recommended": false
    }
  },
  "overrides": [
    {
      "includes": ["**/*.{js,mjs,cjs,ts,tsx,mts,cts}"],
      "linter": {
        "rules": {
          "style": {
            "useConsistentArrowReturn": "error"
          }
        }
      }
    },
    {
      "includes": ["**/*.{ts,tsx,mts,cts}"],
      "linter": {
        "rules": {
          "correctness": {
            "useExhaustiveDependencies": {
              "level": "warn",
              "options": {
                "reportUnnecessaryDependencies": false
              }
            },
            "useHookAtTopLevel": "error"
          }
        }
      }
    },
    {
      "includes": [
        "src/**/*.{ts,tsx}",
        "!src/**/*.stories.tsx",
        "!src/**/*.test.ts",
        "!src/**/*.test.tsx",
        "!src/**/tests/**",
        "!src/test/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "useComponentExportOnlyModules": {
              "level": "warn",
              "options": {
                "allowConstantExport": true
              }
            }
          }
        }
      }
    }
  ],
  "assist": {
    "enabled": false
  }
}
