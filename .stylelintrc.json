{
  "extends": ["stylelint-config-standard"],
  "rules": {
    "selector-class-pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+|[A-Z][a-z0-9]*)*$",
    "keyframes-name-pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+|[A-Z][a-z0-9]*)*$",
    "property-no-vendor-prefix": [
      true,
      {
        "ignoreProperties": [
          "-webkit-mask-position",
          "-webkit-mask-repeat",
          "-webkit-mask-size"
        ]
      }
    ]
  }
}
